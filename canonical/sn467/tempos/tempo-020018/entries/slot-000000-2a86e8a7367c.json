t_mulRight_symm_apply_df7baa1c1030 : ((∀ {R : Type _} [Semiring R] (u : Rˣ) (x : R), (AddEquiv.symm (AddAut.mulRight u)) x = x * ↑u⁻¹) ∧\n    (∀ {R : Type _} [Ring R] {a b : R} [Invertible a] [Invertible b] [Invertible (a + b)] (h : ⅟(a + b) = ⅟a + ⅟b),\n      a * ⅟b * a = b * ⅟a * b)) ∧\n  (∀ {R : Type _} {S : Type _} [NonUnitalNonAssocSemiring R] [NonUnitalNonAssocSemiring S] (f : R →+ S),\n    (∀ (x y : R), f (x * y) = f x * f y) ↔ AddMonoidHom.mul.compr₂ f = (AddMonoidHom.mul.comp f).compl₂ f) := by\n  exact And.intro (And.intro (AddAut.mulRight_symm_apply) eq_of_invOf_add_eq_invOf_add_invOf) AddMonoidHom.map_mul_iff\n\nend Submission\n","proof_sha256":"d775adaf6e90e68d08fc3d8b905f77d80e6e671cd0c52d55c8bdf82804fd8e24","proof_term_hash":"fe6de0263af8e6a901d06ec7fc5a13556fb7278d45bcef441fc52b5613cfd22b","quality":{"baseline_solvers_failed":true,"baseline_solvers_run":["simp","aesop","omega","norm_num"],"dependency_depth":2,"difficulty_band":"easy","license_state":"clean_open","near_duplicate_score":0.0,"triviality_checked":true,"useful_verified_row":true},"queue_depth":0,"queue_position":0,"rewarded":true,"row_id":"2a86e8a7367c6e31a57932e67401d44ef9cba92ac489cb8fc1d21d64a4c5f58e","schema_version":1,"solver_hotkey":"5EHvVWWxbExN8Fmy65yD7SfTpXAHA4gTUtKPHr6q9VLxY5Lx","source_license":"Apache-2.0","source_ref":{"commit":"5450b53e5ddc75d46418fabb605edbf36bd0beb6","kind":"procedural","name":"tempo-20018-seq-2","path":"Mathlib/Algebra/Ring/AddAut.lean"},"source_stream":"procedural","statement":"theorem procedural_AddAut_mulRight_symm_apply_df7baa1c1030 : ((∀ {R : Type _} [Semiring R] (u : Rˣ) (x : R), (AddEquiv.symm (AddAut.mulRight u)) x = x * ↑u⁻¹) ∧\n    (∀ {R : Type _} [Ring R] {a b : R} [Invertible a] [Invertible b] [Invertible (a + b)] (h : ⅟(a + b) = ⅟a + ⅟b),\n      a * ⅟b * a = b * ⅟a * b)) ∧\n  (∀ {R : Type _} {S : Type _} [NonUnitalNonAssocSemiring R] [NonUnitalNonAssocSemiring S] (f : R →+ S),\n    (∀ (x y : R), f (x * y) = f x * f y) ↔ AddMonoidHom.mul.compr