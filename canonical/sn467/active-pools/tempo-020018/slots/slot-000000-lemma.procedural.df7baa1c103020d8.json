ible b] [Invertible (a + b)] (h : ⅟(a + b) = ⅟a + ⅟b),\n      a * ⅟b * a = b * ⅟a * b)) ∧\n  (∀ {R : Type _} {S : Type _} [NonUnitalNonAssocSemiring R] [NonUnitalNonAssocSemiring S] (f : R →+ S),\n    (∀ (x y : R), f (x * y) = f x * f y) ↔ AddMonoidHom.mul.compr₂ f = (AddMonoidHom.mul.comp f).compl₂ f) := by\n  sorry\n\nend Submission\n","target_sha256":"86a46d931e676c8144c383c4a6c8a4e5fc35e5d81c5d1286caab3f60d0919451","task_version":1,"theorem_name":"procedural_AddAut_mulRight_symm_apply_df7baa1c1030","title":"Procedural AddAut.mulRight_symm_apply","triviality_status":"paid_easy","type_expr":"((∀ {R : Type _} [Semiring R] (u : Rˣ) (x : R), (AddEquiv.symm (AddAut.mulRight u)) x = x * ↑u⁻¹) ∧\n    (∀ {R : Type _} [Ring R] {a b : R} [Invertible a] [Invertible b] [Invertible (a + b)] (h : ⅟(a + b) = ⅟a + ⅟b),\n      a * ⅟b * a = b * ⅟a * b)) ∧\n  (∀ {R : Type _} {S : Type _} [NonUnitalNonAssocSemiring R] [NonUnitalNonAssocSemiring S] (f : R →+ S),\n    (∀ (x y : R), f (x * y) = f x * f y) ↔ AddMonoidHom.mul.compr₂ f = (AddMonoidHom.mul.comp f).compl₂ f)","verifier_id":"lake-build","verifier_version":"lemma-lean-v1"}
